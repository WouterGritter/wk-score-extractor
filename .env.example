# Copy to .env and fill in. .env is gitignored (contains a secret).

# Discord webhook that score updates are posted to.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXXXXXX

# Optional overrides used by docker-compose (defaults shown).
HDHR_IP=10.43.70.192
CHANNEL=1

# Run OCR on the GPU (needs the GPU image / onnxruntime-gpu + a CUDA runtime).
# Baked into Dockerfile.gpu; set it here only for a non-Docker GPU run.
# USE_CUDA=1
