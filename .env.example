# Copy to .env and fill in. .env is gitignored (contains a secret).

# Discord webhook that score updates are posted to.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXXXXXXXXXX

# Optional overrides used by docker-compose (defaults shown).
HDHR_IP=10.43.70.192
CHANNEL=1

# Run OCR on the GPU (needs the GPU image / onnxruntime-gpu + a CUDA runtime).
# Baked into Dockerfile.gpu; set it here only for a non-Docker GPU run.
# USE_CUDA=1

# --- Goal-replay clips (post a short video to Discord on each goal) ---
# Enabled by default in both compose files (ring buffer on an in-RAM tmpfs).
# CLIP_ENABLE=1
# CLIP_SECONDS=25           # clip length (trailing seconds before detection)
# CLIP_POSTROLL=5           # wait after a goal before cutting (catch the celebration)
# CLIP_HEIGHT=720           # output height in px (width auto)
# CLIP_BITRATE=auto         # 'auto' sizes bitrate to CLIP_MAX_MB so it always fits
# CLIP_MAX_MB=10            # Discord cap: 10 non-boosted, 25 (Tier 1) / 100 (Tier 3)
# CLIP_NVENC=1              # encode on GPU (h264_nvenc); needs an nvenc ffmpeg build
# CLIP_BUFFER_DIR=/buf      # ring dir; put it on a tmpfs (compose mounts one here)
